{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "GClaw",
  "version": "0.1.0",
  "identifier": "com.gclaw.desktop",
  "build": {
    "beforeBuildCommand": "bash src-tauri/scripts/setup-runtimes.sh && npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3100",
    "frontendDist": "./frontend"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "server/server.js",
      "server/package.json",
      "server/.next/**/*",
      "server/node_modules/**/*",
      "server/skills/**/*",
      "python/bin/**/*",
      "python/lib/**/*",
      "python/include/**/*",
      "node/bin/**/*",
      "node/lib/**/*"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ]
  }
}
